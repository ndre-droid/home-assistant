<resources>
    <style name="Theme.HomeFlow" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ic_bg</item>
        <item name="android:statusBarColor">@color/ic_bg</item>
        <item name="android:navigationBarColor">@color/ic_bg</item>
    </style>
    <style name="WidgetBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:background">@drawable/widget_btn_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">6dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">2</item>
        <item name="android:textColor">@color/widget_text</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
